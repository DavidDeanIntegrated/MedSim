# MedSim Environment Configuration
# Copy to .env and update values for your deployment

# --- Application ---
APP_NAME=MedSim
APP_ENV=development          # development | production
HOST=0.0.0.0
PORT=8000
DATA_DIR=app/data
SESSION_DIR=app/data/sessions
DEFAULT_CASE_ID=htn_enceph_001

# --- Database ---
# SQLite (local development):
DATABASE_URL=sqlite:///./medsim.db
# PostgreSQL (production via Supabase):
# DATABASE_URL=postgresql://user:password@host:5432/medsim

# --- Authentication ---
JWT_SECRET=CHANGE-THIS-TO-A-RANDOM-SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440      # 24 hours

# --- LLM Parser (optional) ---
LLM_PARSER_ENABLED=false
ANTHROPIC_API_KEY=            # Leave empty to use rule-based parser only
LLM_PARSER_MODEL=claude-sonnet-4-20250514

# --- LTI 1.3 (optional, for Canvas/Blackboard) ---
# LTI_ISSUER=https://canvas.instructure.com
# LTI_CLIENT_ID=your-client-id
# LTI_DEPLOYMENT_ID=your-deployment-id
# LTI_AUTH_ENDPOINT=https://canvas.instructure.com/api/lti/authorize_redirect
# LTI_TOKEN_ENDPOINT=https://canvas.instructure.com/login/oauth2/token
# LTI_JWKS_URL=https://canvas.instructure.com/api/lti/security/jwks
