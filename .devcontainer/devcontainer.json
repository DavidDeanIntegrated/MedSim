{
  "name": "MedSim Clinical Backend",
  "image": "mcr.microsoft.com/vscode/devcontainers/python:3.11",
  "postCreateCommand": "cd clinical-sim-backend-bundle-fresh-20260226-222555/clinical-sim-backend && pip install -e .[dev]",
  "postAttachCommand": "cd clinical-sim-backend-bundle-fresh-20260226-222555/clinical-sim-backend && uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "FastAPI",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python"
      }
    }
  }
}
